# Copy this file to .env.local and fill in your values.
# Find Supabase keys in your project dashboard → Project Settings → API.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional. Without this, Google Books often returns HTTP 429 (shared anonymous quota).
# Open Library is used first and still works without a key.
# VITE_GOOGLE_BOOKS_API_KEY=

# ---------------------------------------------------------------------------
# Server-only (never prefix with VITE_ — those are embedded in the browser).
# Set in Vercel → Environment Variables and in .env.local for local admin.
# ---------------------------------------------------------------------------
# Your normal login email (same one you sign in with). That session can open /admin.
# ADMIN_EMAIL=you@example.com
# Optional signing secret for admin session tokens:
# ADMIN_SESSION_SECRET=
